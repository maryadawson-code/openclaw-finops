{
  "name": "openclaw-suite",
  "version": "1.0.0",
  "private": true,
  "description": "OpenClaw Suite — Revenue-gated MCP servers for AI agents",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @openclaw/finops dev",
    "dev:finops": "pnpm --filter @openclaw/finops dev",
    "dev:api-bridge": "pnpm --filter @openclaw/api-bridge dev",
    "deploy:finops": "pnpm --filter @openclaw/finops deploy",
    "deploy:api-bridge": "pnpm --filter @openclaw/api-bridge deploy",
    "dev:guardrail": "pnpm --filter @openclaw/guardrail dev",
    "dev:fortress": "pnpm --filter @openclaw/fortress dev",
    "deploy:fortress": "pnpm --filter @openclaw/fortress deploy",
    "deploy:guardrail": "pnpm --filter @openclaw/guardrail deploy",
    "dev:ambassador": "pnpm --filter @openclaw/ambassador dev",
    "deploy:ambassador": "pnpm --filter @openclaw/ambassador deploy",
    "deploy:all": "pnpm -r deploy",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "tsx": "^4.21.0",
    "turbo": "^2.5.0"
  }
}
